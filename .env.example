# Copy this file to .env and fill in your real API keys.
# NEVER commit your real .env file.

# Google Gemini API key (https://aistudio.google.com/app/apikey)
GEMINI_API_KEY=your_gemini_api_key_here

# Tavily Search API key (https://app.tavily.com/)
TAVILY_API_KEY=your_tavily_api_key_here

# Anthropic (Claude) API key — needed only for claude-* models (https://console.anthropic.com/)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# OpenAI API key — needed only for gpt-* models (https://platform.openai.com/api-keys)
OPENAI_API_KEY=your_openai_api_key_here

# Meta Llama API key — needed only for llama-* models (https://llama.developer.meta.com/)
LLAMA_API_KEY=your_llama_api_key_here
# Optional: point Llama at any OpenAI-compatible host (Meta default shown; or Ollama/Groq/Together/vLLM).
# For a keyless local endpoint (Ollama), set LLAMA_API_KEY to any non-empty value.
# LLAMA_BASE_URL=https://api.llama.com/compat/v1

# Optional: client-side requests-per-minute caps per provider
# (defaults: gemini 15, anthropic 50, openai 60, llama 30). A client limiter
# prevents bursting; it cannot raise your account's real quota.
# GEMINI_MAX_RPM=10
# ANTHROPIC_MAX_RPM=50
# OPENAI_MAX_RPM=60
# LLAMA_MAX_RPM=30

# Optional: shared generation controls (apply to all providers).
# LLM_MAX_OUTPUT_TOKENS caps output length (default 8192) to prevent runaway,
# unscoreable responses. LLM_TIMEOUT_SECONDS is the per-call timeout (default 120).
# LLM_SEED enables best-effort reproducible generation where supported
# (OpenAI/Gemini; Anthropic has no seed) — set it for repeatable experiment metrics.
# LLM_MAX_OUTPUT_TOKENS=8192
# LLM_TIMEOUT_SECONDS=120
# LLM_SEED=42
